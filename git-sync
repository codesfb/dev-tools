#!/usr/bin/env bash
set -e


cd "$(git rev-parse --show-toplevel)"

clear
echo "======================================"
echo "          Git Sync"
echo "======================================"
echo
git status --short
echo

# ----------------------------
# Stage Mode
# ----------------------------
echo "Stage mode"
echo "1) Stage all changes"
echo "2) Stage interactively (git add -p)"
echo "3) Select files from list"
echo
read -rp "Choice: " stage

case "$stage" in
1)
    git add -A
    ;;
2)
    git add -p
    ;;
3)
    mapfile -t files < <(git status --short | awk '{print $2}')

    if [ "${#files[@]}" -eq 0 ]; then
        echo "No changed files."
        exit 0
    fi

    echo
    echo "Files:"
    for i in "${!files[@]}"; do
        printf "  %d) %s\n" "$((i+1))" "${files[$i]}"
    done
    echo
    read -rp "Enter numbers separated by space (e.g. 1 3 4), or 'a' for all: " selection

    if [ "$selection" = "a" ] || [ "$selection" = "A" ]; then
        git add -A
    else
        for num in $selection; do
            idx=$((num-1))
            if [ "$idx" -ge 0 ] && [ "$idx" -lt "${#files[@]}" ]; then
                git add "${files[$idx]}"
            else
                echo "Invalid number ignored: $num"
            fi
        done
    fi
    ;;
*)
    echo "Invalid option."
    exit 1
    ;;
esac

echo
echo "Staged files:"
git diff --cached --name-only
echo

# ----------------------------
# Commit Type
# ----------------------------
echo "Commit type"
echo "1) feat"
echo "2) fix"
echo "3) docs"
echo "4) refactor"
echo "5) style"
echo "6) test"
echo "7) chore"
echo "8) perf"
echo "9) ci"
echo "10) build"
echo "11) revert"
echo "12) Auto"
echo
read -rp "Choice: " choice

case "$choice" in
1) type="feat" ;;
2) type="fix" ;;
3) type="docs" ;;
4) type="refactor" ;;
5) type="style" ;;
6) type="test" ;;
7) type="chore" ;;
8) type="perf" ;;
9) type="ci" ;;
10) type="build" ;;
11) type="revert" ;;
12)
    git commit -m "chore: update project"
    git push
    echo
    echo "Done!"
    exit 0
    ;;
*)
    echo "Invalid option."
    exit 1
    ;;
esac

echo
read -rp "Description: " description
git commit -m "$type: $description"
echo
git push
echo
echo "Done!"
